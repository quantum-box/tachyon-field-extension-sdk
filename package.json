{
  "name": "tachyon-field-extension-sdk",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "workspaces": [
    "packages/*",
    "examples/*"
  ],
  "scripts": {
    "build": "npm run build --workspaces --if-present",
    "lint": "biome lint .",
    "format": "biome format .",
    "format:write": "biome format --write .",
    "test": "npm run test --workspaces --if-present",
    "ts": "npm run ts --workspaces --if-present"
  },
  "devDependencies": {
    "@biomejs/biome": "^1.9.4",
    "typescript": "^5.2.2",
    "vitest": "^4.1.8"
  },
  "engines": {
    "node": ">=20"
  }
}
